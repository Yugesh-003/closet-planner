# ClosetMind Frontend Environment Variables
# Copy this file to .env and fill in your actual values after deployment

# API Gateway URL (get this from SAM deployment outputs)
VITE_API_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/prod

# Cognito Configuration (get these from SAM deployment outputs)
VITE_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_USER_POOL_CLIENT_ID=your-client-id-here

# Optional: Weather API Key (if implementing weather features)
VITE_WEATHER_API_KEY=your-openweathermap-api-key
