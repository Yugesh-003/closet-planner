# ClosetMind Backend Environment Variables
# These are set automatically by AWS SAM during deployment
# This file is for local development reference only

# DynamoDB Tables (auto-configured by SAM)
USERS_TABLE=closetmind-users
WARDROBE_TABLE=closetmind-wardrobe
OUTFITS_TABLE=closetmind-outfits
EVENTS_TABLE=closetmind-events

# Cognito (auto-configured by SAM)
USER_POOL_ID=us-east-1_XXXXXXXXX
USER_POOL_CLIENT_ID=your-client-id-here

# Weather API (you need to provide this in SAM parameters)
WEATHER_API_KEY=your-openweathermap-api-key
